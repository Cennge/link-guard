{
  "manifest_version": 3,
  "name": "LinkGuard — защита от фишинга",
  "version": "1.0.0",
  "description": "Реальная защита от тайпосквоттинга и гомографических (IDN) фишинговых атак, маскирующихся под популярные бренды.",
  "minimum_chrome_version": "102",
  "permissions": [
    "webNavigation",
    "storage",
    "activeTab"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "LinkGuard"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

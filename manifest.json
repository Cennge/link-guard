{
  "manifest_version": 3,
  "name": "LinkGuard — защита от фишинга",
  "version": "1.0.0",
  "description": "Реальная защита от тайпосквоттинга и гомографических (IDN) фишинговых атак, маскирующихся под популярные бренды.",
  "minimum_chrome_version": "111",
  "permissions": [
    "webNavigation",
    "storage",
    "unlimitedStorage",
    "activeTab",
    "declarativeNetRequest",
    "alarms"
  ],
  "host_permissions": [
    "https://urlhaus.abuse.ch/*",
    "https://raw.githubusercontent.com/*",
    "https://openphish.com/*",
    "https://pgl.yoyo.org/*"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      { "id": "ads", "enabled": true, "path": "rules/ads.json" },
      { "id": "ads-regex", "enabled": true, "path": "rules/ads-regex.json" },
      { "id": "ads-allow", "enabled": true, "path": "rules/ads-allow.json" },
      { "id": "ads-net-0", "enabled": false, "path": "rules/ads-net-0.json" },
      { "id": "ads-net-1", "enabled": false, "path": "rules/ads-net-1.json" },
      { "id": "ads-net-2", "enabled": false, "path": "rules/ads-net-2.json" },
      { "id": "ads-net-3", "enabled": false, "path": "rules/ads-net-3.json" },
      { "id": "ads-net-4", "enabled": false, "path": "rules/ads-net-4.json" },
      { "id": "ads-net-5", "enabled": false, "path": "rules/ads-net-5.json" }
    ]
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/gate.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/antipopup.main.js", "content/scriptlets.main.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "LinkGuard"
  },
  "web_accessible_resources": [
    { "resources": ["redirect/*"], "matches": ["<all_urls>"] }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

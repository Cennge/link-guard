{
  "manifest_version": 3,
  "name": "LinkGuard — защита от фишинга",
  "version": "1.0.0",
  "description": "Реальная защита от тайпосквоттинга и гомографических (IDN) фишинговых атак, маскирующихся под популярные бренды.",
  "minimum_chrome_version": "111",
  "permissions": [
    "webNavigation",
    "storage",
    "unlimitedStorage",
    "activeTab",
    "scripting",
    "declarativeNetRequest",
    "alarms"
  ],
  "host_permissions": [
    "https://urlhaus.abuse.ch/*",
    "https://raw.githubusercontent.com/*",
    "https://openphish.com/*",
    "https://pgl.yoyo.org/*"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      { "id": "ads", "enabled": true, "path": "rules/ads.json" },
      { "id": "ads-extra", "enabled": true, "path": "rules/ads-extra.json" },
      { "id": "ads-regex", "enabled": true, "path": "rules/ads-regex.json" }
    ]
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "LinkGuard"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
